// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  name      String
  isAdmin   Boolean @default(false)
  createdAt DateTime @default(now())

  storageNodes StorageNode[]
  permissions     UserPermission?
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events Event[]
}

model Event {
  id        Int @id @default(autoincrement())
  name      String
  type      String 
  date      DateTime
  location  String
  notes     String?
  clientId  Int
  client    Client  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  transactions FinancialTransaction[]
  paymentMonths EventPaymentMonth[]
  checklist EventChecklist[]
  group EventGroup[]
  storageNodes StorageNode[]
}

model Participant {
  id        Int      @id @default(autoincrement())
  eventId   Int
  name      String
  groupId   Int?  
  createdAt DateTime @default(now())

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group       EventGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  collections Collection[]

  @@index([eventId])
  @@index([eventId, groupId])
  @@map("collection_participant")
}

model Collection {
  id             Int   @id @default(autoincrement())
  participantId  Int
  referenceMonth String 
  amount         Decimal  @db.Decimal(10,2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, referenceMonth])
  @@index([referenceMonth])
  @@index([participantId])
  
}

model FinancialCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FinancialTransaction[]

  @@map("financial_category")
}

enum FinancialType {
  income
  expense
}

enum FinancialStatus {
  planned
  settled
}

enum FinancialSourceType {
  manual
  collection
}

enum AccessLevel {
  none
  view
  manage
}

model FinancialTransaction {
  id          Int      @id @default(autoincrement())
  eventId     Int
  type        FinancialType
  status      FinancialStatus
  amount      Decimal  @db.Decimal(10,2)

  description String

  categoryId  Int?
  category    FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  paidAt      DateTime?

  sourceType  FinancialSourceType @default(manual)
  sourceId    Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([categoryId])
  @@index([type])
  @@index([status])
  @@unique([sourceType, sourceId])

  @@map("financial_transaction")
}

model EventPaymentMonth {
  id      Int    @id @default(autoincrement())
  eventId Int
  month   String @db.VarChar(7)

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, month])
  @@index([eventId])
  @@index([month])

  @@map("event_payment_months")
}

model EventChecklist {
  id      Int    @id @default(autoincrement())
  eventId Int
  date      DateTime?
  done      Boolean  @default(false)
  text String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_checklist")
}

model EventGroup {
  id      Int    @id @default(autoincrement())
  eventId Int
  text String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@map("event_group")
}

enum StorageNodeType {
  folder
  file
}

model StorageNode {
  id          Int             @id @default(autoincrement())
  eventId     Int
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentId    Int?
  parent      StorageNode?    @relation("StorageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    StorageNode[]   @relation("StorageTree")
  type        StorageNodeType
  name        String
  mimeType    String?         @db.VarChar(128)
  size        Int?    
  storageKey  String?       
  thumbKey    String?      
  createdById Int?
  createdBy   User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([eventId, parentId, createdAt])
  @@index([eventId, parentId, name])
  @@index([eventId, type])

  @@unique([eventId, parentId, name])
}

model UserPermission {
  id                 Int         @id @default(autoincrement())
  userId             Int         @unique
  financialAccess    AccessLevel @default(none)
  recordsAccess      AccessLevel @default(none)
  attachmentsAccess  AccessLevel @default(none)
  collectionsAccess  AccessLevel @default(none)
  eventsAccess       AccessLevel @default(none)
  usersAccess        AccessLevel @default(none)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_permission")
}